{
  "name": "effective-bassoon",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "effective-bassoon",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^5.6.3"
      },
      "optionalDependencies": {
        "@playwright/test": "^1.52.0"
      }
    },
    "apps/backend": {
      "name": "@apps/backend",
      "version": "0.1.0"
    },
    "apps/frontend": {
      "name": "@apps/frontend",
      "version": "0.1.0",
      "dependencies": {
        "@packages/types": "0.1.0"
      }
    },
    "node_modules/@apps/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@apps/frontend": {
      "resolved": "apps/frontend",
      "link": true
    },
    "node_modules/@packages/types": {
      "resolved": "packages/types",
      "link": true
    },
    "node_modules/@packages/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "node_modules/@packages/utils": {
      "resolved": "packages/utils",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/types": {
      "name": "@packages/types",
      "version": "0.1.0"
    },
    "packages/ui": {
      "name": "@packages/ui",
      "version": "0.1.0"
    },
    "packages/utils": {
      "name": "@packages/utils",
      "version": "0.1.0"
    }
  }
}
