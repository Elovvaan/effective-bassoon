{
  "name": "@apps/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test",
    "lint": "tsc -p tsconfig.json --noEmit",
    "format": "echo 'No formatter configured for @apps/backend'",
    "clean": "rm -rf dist",
    "seed": "ts-node src/seed.ts",
    "dev": "node --watch --loader ts-node/esm src/main.ts",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@packages/types": "0.1.0",
    "@prisma/client": "^6.6.0",
    "express": "^4.21.2",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2",
    "prisma": "^6.6.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
